---
Language: Cpp
# Use K&R style
BreakBeforeBraces: Attach
# Indent width
IndentWidth: 2
# Always break after template declarations
AlwaysBreakTemplateDeclarations: Yes
# Don't indent public/private/protected
AccessModifierOffset: -2
# Align parameters
AlignAfterOpenBracket: Align
# Other useful settings
AllowShortBlocksOnASingleLine: false
AllowShortFunctionsOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: false
AllowShortLoopsOnASingleLine: false
# Keep parameters on the same line if possible
BinPackParameters: true
# Column limit
ColumnLimit: 100
# Indent case labels
IndentCaseLabels: true
# Space before parentheses
SpaceBeforeParens: ControlStatements
# Spaces in parentheses
SpacesInParentheses: false
# Sort includes with custom priority to ensure OpenGL headers come before CUDA
SortIncludes: CaseSensitive
IncludeBlocks: Regroup
IncludeCategories:
  # Priority 1: Main project header (for .cpp files)
  - Regex: '^"'
    Priority: 1
  # Priority 2: OpenGL-related headers (GLAD, GL, etc.) - must come before CUDA
  - Regex: "<(glad|GL)/"
    Priority: 2
  # Priority 3: CUDA headers - must come after OpenGL
  - Regex: "<cuda"
    Priority: 3
  # Priority 4: SDL headers
  - Regex: "<SDL"
    Priority: 4
  # Priority 5: Third-party libraries
  - Regex: "<(glm|artery_font|lodepng|FastNoiseLite|imgui|Random123)/"
    Priority: 5
  # Priority 6: Standard library
  - Regex: "<[a-z_]+>"
    Priority: 6
